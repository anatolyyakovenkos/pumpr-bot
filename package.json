{
  "name": "pumpr-bot",
  "version": "1.0.0",
  "description": "AI-powered Solana trading bot built on the official PumpFun SDK. Forked from Bankr Bot.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "launch": "tsx src/commands/launch.ts",
    "snipe": "tsx src/commands/snipe.ts",
    "trade": "tsx src/commands/trade.ts",
    "portfolio": "tsx src/commands/portfolio.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "solana",
    "pumpfun",
    "trading-bot",
    "ai-agent",
    "memecoin",
    "defi",
    "bonding-curve",
    "sniper"
  ],
  "author": "Pumpr Team",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.3",
    "pumpdotfun-sdk": "^1.3.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
