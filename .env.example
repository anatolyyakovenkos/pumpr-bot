# Solana RPC endpoint (use a paid RPC for production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Your wallet private key (base58 encoded)
WALLET_PRIVATE_KEY=

# Trading configuration
DEFAULT_SLIPPAGE_BPS=200
DEFAULT_BUY_AMOUNT_SOL=0.1
PRIORITY_FEE_UNIT_LIMIT=250000
PRIORITY_FEE_UNIT_PRICE=250000

# Sniper configuration
SNIPE_ENABLED=false
SNIPE_BUY_AMOUNT_SOL=0.05
SNIPE_MAX_SLIPPAGE_BPS=500
SNIPE_FILTER_MIN_SOL_IN_CURVE=0
SNIPE_FILTER_MAX_SOL_IN_CURVE=50

# AI Agent mode
AI_AGENT_ENABLED=false
AI_MODEL=gpt-4
AI_API_KEY=

# Logging
LOG_LEVEL=info
